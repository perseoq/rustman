# ===========================================
# Rust / Cargo
# ===========================================
# Build artifacts
/target/
/target/**/*
!**/target/.gitkeep
!**/target/release/.gitkeep
!**/target/debug/.gitkeep

# Cargo.lock - Comentar la siguiente línea si usas librerías binarias
# Para aplicaciones (binarios), descomenta para tracking de versiones
# Cargo.lock

# Crate de test coverage
*.prof
*.gcda
*.gcno
coverage/
tarpaulin-report.html
cargo-coverage/

# Benchmark outputs
bencher/

# ===========================================
# Entornos y secrets
# ===========================================
# Archivos de variables de entorno
.env
.env.local
.env.development
.env.production
.env.test
.env.*.local

# Certificados y claves
*.pem
*.key
*.crt
*.cert
secrets/
.secrets/

# ===========================================
# Base de datos
# ===========================================
# SQLite
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# MySQL / MariaDB
*.sql.gz
*.mysql
*.myd
*.myi
*.frm

# PostgreSQL
*.pg_dump
*.psql

# Backups
*.bak
*.backup
*.old
dump.sql
database.sql
mysql-data/

# ===========================================
# Logs
# ===========================================
*.log
*.log.*
logs/
*.pid
*.seed
*.pid.lock

# Logs de testing
test-output/
junit.xml
coverage.xml

# ===========================================
# Editores e IDEs
# ===========================================
# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
*.code-workspace

# IntelliJ / JetBrains
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# Vim
*.swp
*.swo
*.vimrc.local
.vim/

# Emacs
*~
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# Eclipse
.classpath
.project
.settings/
bin/
*.launch

# ===========================================
# Sistemas operativos
# ===========================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
applescript.txt

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
$RECYCLE.BIN
*.lnk

# Linux
*~
.fuse_hidden*
.Trash-*
.nfs*

# ===========================================
# Docker
# ===========================================
# Volúmenes y datos de contenedores
docker-data/
.docker-data/
*.dockerfile.local
docker-compose.override.yml
docker-compose.override.yaml

# ===========================================
# Node.js (si se usa para tooling)
# ===========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.yarn/
.pnpm-store/

# ===========================================
# Python (si se usa para scripts auxiliares)
# ===========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv/
.env.bak

# ===========================================
# Java (si se usa para alguna integración)
# ===========================================
*.class
*.jar
*.war
*.ear
hs_err_pid*

# ===========================================
# Build outputs de otros lenguajes
# ===========================================
# C / C++
*.o
*.obj
*.exe
*.dll
*.so
*.dylib
*.a
*.lib

# JavaScript compilado
*.min.js
*.min.css

# ===========================================
# Archivos temporales
# ===========================================
*.tmp
*.temp
*.swp
*.bak
*.orig
*.rej
*.swp
*~
.DS_Store
*.swp
*.*~

# ===========================================
# Outputs de tests y documentación
# ===========================================
test-results/
test_report.html
target/doc/
target/.rustc_info.json
target/.fingerprint/

# ===========================================
# Cache local
# ===========================================
.cache/
.cache
.cargo/
.local/

# ===========================================
# Kubernetes / Terraform (si se usan)
# ===========================================
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock
*.tfvars
!*.tfvars.example

# ===========================================
# Archivos específicos del proyecto
# ===========================================

# Datos persistentes de MariaDB/MySQL (de podman run)
podman-data/
mysql_data/
postgres-data/
redis-data/

# Archivos de configuración local (no committir)
config.local.toml
config.local.yaml
config.local.json

# Credenciales de PAC (Facturama, etc.)
.pac-credentials
.pac-token

# Archivos generados automáticamente
*.generated.rs
*.generated.json
/generated/

# Backups locales
*.tar.gz
*.zip
!manual_rust.md
!proyectos_capitulo/
!proyecto_api/

# ===========================================
# Carpetas que se crean durante el uso
# ===========================================

# Datos de la BD cuando se inicializa con docker-compose
proyecto_api/mysql_data/
proyecto_api/postgres-data/
proyecto_api/redis-data/

# Reportes de cobertura
htmlcov/
.coverage
.coverage.*

# Sphinx docs (no se usa aquí, pero por si acaso)
docs/_build/
docs/.doctrees/

# ===========================================
# Permitir explícitamente ciertos archivos
# ===========================================
!.gitkeep
!.gitignore
!README.md
!LICENSE
!*.md
!manual_rust.md
!AGENT.md
!requisitos_del_manual.md
!proyectos_capitulo/*/Cargo.toml
!proyectos_capitulo/*/Cargo.lock
!proyectos_capitulo/*/src/*.rs
!proyectos_capitulo/*/README.md
!proyecto_api/*/Cargo.toml
!proyecto_api/*/Cargo.lock
!proyecto_api/*/src/*.rs
!proyecto_api/*/README.md
!proyecto_api/sql/init.sql
!proyecto_api/docker-compose.yml
!proyecto_api/api_diesel/Dockerfile
!proyecto_api/api_seaorm/Dockerfile
